{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "types": ["node"],
    "noUncheckedSideEffectImports": true
  },
  "include": ["vite.config.ts", "tailwind.config.ts"]
}
